# NextAuth
NEXTAUTH_SECRET=your-random-secret-min-32-chars   # generate: openssl rand -base64 32
NEXTAUTH_URL=https://your-dashboard.vercel.app     # local: http://localhost:3000

# Google OAuth (create credentials at console.cloud.google.com → Credentials → OAuth 2.0)
# Authorized redirect URIs: https://your-dashboard.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxx

# Allowed Google accounts (comma-separated). Leave empty to allow any authenticated Google user.
# Admin = sees all receipts. Future: non-admin sees only their own (via google_email → line_user_id mapping).
ADMIN_EMAILS=ccsonytv@gmail.com

# Supabase — server-only (no NEXT_PUBLIC_ prefix; never sent to browser)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJxxx
