# LINE Messaging API
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token
LINE_CHANNEL_SECRET=your_line_channel_secret

# Gemini AI (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash

# Supabase (Settings → API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# Google Service Account — choose ONE:
# Local dev: path to downloaded JSON file
GOOGLE_SA_JSON_PATH=/path/to/service-account.json
# Render deployment: base64-encoded JSON (run: base64 -i service-account.json)
# GOOGLE_SA_JSON_B64=base64_encoded_service_account_json

# Google Drive root folder ID (from folder URL)
DRIVE_ROOT_FOLDER_ID=your_google_drive_folder_id

# Google Sheets spreadsheet ID (from sheet URL)
SHEETS_SPREADSHEET_ID=your_google_sheets_id
