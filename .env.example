# LINE Messaging API
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token
LINE_CHANNEL_SECRET=your_line_channel_secret

# Gemini AI (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash

# Supabase (Settings -> API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# Google OAuth2 credentials (one-time setup: run get_refresh_token.py)
# GCP -> APIs & Services -> Credentials -> OAuth 2.0 Client IDs -> Desktop app
GOOGLE_CLIENT_ID=your_oauth2_client_id
GOOGLE_CLIENT_SECRET=your_oauth2_client_secret
GOOGLE_REFRESH_TOKEN=your_oauth2_refresh_token

# Google Drive root folder ID (from folder URL: drive.google.com/drive/folders/THIS_PART)
DRIVE_ROOT_FOLDER_ID=your_google_drive_folder_id

# Google Sheets spreadsheet ID (from sheet URL: docs.google.com/spreadsheets/d/THIS_PART)
SHEETS_SPREADSHEET_ID=your_google_sheets_id
